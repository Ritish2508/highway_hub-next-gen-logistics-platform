# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Kubernetes (in-cluster auto-detected on EKS; local = kubeconfig)
K8S_IN_CLUSTER=false
KUBECONFIG_PATH=/root/.kube/config

# Jenkins
JENKINS_URL=http://jenkins:8080
JENKINS_USER=admin
JENKINS_TOKEN=your_api_token

# Prometheus
PROMETHEUS_URL=http://prometheus:9090

# SonarQube
SONAR_URL=http://sonarqube:9000
SONAR_TOKEN=your_sonar_token
SONAR_PROJECT_KEY=highwayhub

# Backend health
BACKEND_URL=http://backend:3000
FRONTEND_URL=http://frontend:5173

# MongoDB (reuse your existing instance)
MONGODB_URI=mongodb://mongo:27017/highwayhub_agent

# Agent
AGENT_MODE=readonly   # readonly | approval
CORS_ORIGINS=http://localhost:5173,http://localhost:3000